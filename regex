# Enter your code here. Read input from STDIN. Print output to STDOUT
import re

def replace_logic(match):
    # This function is called for each match (either '&&' or '||')
    if match.group(1) == '&&':
        return 'and'
    else:
        return 'or'

# Read input lines
n = int(input())
text = ""
for _ in range(n):
    text += input() + "\n"

# Use re.sub with a lambda or function to replace the matched symbols
# The regex uses positive lookbehind (?<= ) and positive lookahead (?= )
# to ensure the symbols are surrounded by spaces without including the spaces
# in the match itself.
pattern = r'(?<= )(&&|\|\|)(?= )'
modified_text = re.sub(pattern, replace_logic, text)

print(modified_text)
